# Machine-specific overrides
Include ~/.ssh/config.local

# Include work-specific config
Include ~/.ssh/config.work

Host *
  HashKnownHosts yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

# 1Password SSH Agent (macOS)
Match host * exec "test -S '%d/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock'"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# 1Password SSH Agent (Linux)
Match host * exec "test -S ~/.1password/agent.sock"
  IdentityAgent ~/.1password/agent.sock
