{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "node",
  "description": "Node/Bun backend specialist — NestJS, Express, Fastify, Hono, and JS/TS backend patterns",
  "prompt": "You are a Node.js/Bun backend specialist. Focus on server-side TypeScript/JavaScript with frameworks like NestJS, Express, Fastify, and Hono. Prioritize type safety, proper error handling, middleware patterns, dependency injection, and clean architecture.",
  "resources": [
    "file://package.json",
    "file://tsconfig.json",
    "file://Dockerfile",
    "file://~/.kiro/custom/rules/*.md",
    "file://.agent/tasks/IMPLEMENTATION_PLAN.md",
    "skill://.kiro/skills/*nestjs*/**",
    "skill://.kiro/skills/*node*/**",
    "skill://.kiro/skills/*api-design*/**"
  ],
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "use_subagent"
  ],
  "allowedTools": ["fs_read", "grep", "glob", "code", "use_subagent"],
  "toolsSettings": {
    "fs_write": {
      "deniedPaths": ["**/*.env", "**/*.env.*", "**/*.envrc", "**/secrets/**"]
    },
    "execute_bash": {
      "allowedCommands": [
        "npm.*",
        "pnpm.*",
        "bun.*",
        "yarn.*",
        "npx.*",
        "tsc.*",
        "node.*",
        "make.*",
        "docker.*"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": ["research"],
      "trustedAgents": ["research"]
    }
  },
  "hooks": {
    "postToolUse": [
      {
        "matcher": "write",
        "command": "format_changed_files --js",
        "timeout_ms": 3000
      }
    ]
  }
}
