{
  "name": "react",
  "description": "Specialized agent for React development with TypeScript, modern patterns, and best practices",
  "prompt": "You are a React specialist focused on modern React development with TypeScript. Prioritize functional components, hooks, performance optimization, and accessibility. Use current best practices for state management, testing, and component architecture.",
  "resources": [
    "file://package.json",
    "file://tsconfig.json",
    "file://~/.kiro/custom/rules/*.md",
    "file://.agent/tasks/IMPLEMENTATION_PLAN.md",
    "skill://.kiro/skills/*react*/SKILL.md"
  ],
  "tools": ["*"],
  "toolsSettings": {
    "fs_read": {
      "deniedPaths": ["**/*.env", "**/*.env.*", "**/*.envrc", "**/secrets/**"]
    },
    "fs_write": {
      "deniedPaths": ["**/*.env", "**/*.env.*", "**/*.envrc", "**/secrets/**"]
    },
    "execute_bash": {
      "allowedCommands": [
        "ast-grep.*",
        "awk.*",
        "biome.*",
        "bun.*",
        "cargo.*",
        "cat.*",
        "cloc.*",
        "cp.*",
        "date.*",
        "diff.*",
        "fd.*",
        "find.*",
        "fnm.*",
        "fzf.*",
        "git(?! push).*",
        "go .*",
        "grep.*",
        "rg.*",
        "gsed.*",
        "head.*",
        "jq.*",
        "ls.*",
        "mkdir.*",
        "npm.*",
        "pnpm.*",
        "prettier.*",
        "pwd",
        "sed.*",
        "sg.*",
        "shellcheck.*",
        "sort.*",
        "stow.*",
        "stylua.*",
        "tail.*",
        "tar.*",
        "touch.*",
        "tr.*",
        "tree.*",
        "tsc.*",
        "turbo.*",
        "uniq.*",
        "unzip.*",
        "vite.*",
        "vitest.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "yarn.*",
        "zip.*",
        "zoxide.*"
      ],
      "deniedCommands": ["git push.*"],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": ["research"],
      "trustedAgents": ["research"]
    }
  },
  "hooks": {
    "postToolUse": [
      {
        "matcher": "write",
        "command": "format_changed_files",
        "timeout_ms": 3000
      }
    ]
  }
}
