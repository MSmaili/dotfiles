{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "default",
  "description": "General development — lean, no MCP. Delegates to specialized agents when needed.",
  "prompt": "You are a general development assistant.\n\nWhen you need latest library/framework docs or web search, delegate to the 'research' agent using the agent tool.\nDon't tell the user to switch agents — just delegate and bring back the answer.",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "use_subagent"
  ],
  "allowedTools": ["fs_read", "grep", "glob", "code", "use_subagent"],
  "toolsSettings": {
    "fs_read": {
      "deniedPaths": ["**/*.env", "**/*.env.*", "**/*.envrc", "**/secrets/**"]
    },
    "fs_write": {
      "deniedPaths": [
        "**/*.env",
        "**/*.env.*",
        "**/*.envrc",
        "**/secrets/**",
        "~/.zshrc.local"
      ]
    },
    "execute_bash": {
      "allowedCommands": [
        "ast-grep.*",
        "awk.*",
        "biome.*",
        "bun.*",
        "cargo.*",
        "cat.*",
        "cloc.*",
        "cp.*",
        "date.*",
        "diff.*",
        "fd.*",
        "find.*",
        "fnm.*",
        "fzf.*",
        "git(?! push).*",
        "go .*",
        "grep.*",
        "rg.*",
        "gsed.*",
        "head.*",
        "jq.*",
        "ls.*",
        "mkdir.*",
        "npm.*",
        "pnpm.*",
        "prettier.*",
        "pwd",
        "sed.*",
        "sg.*",
        "shellcheck.*",
        "sort.*",
        "stow.*",
        "stylua.*",
        "tail.*",
        "tar.*",
        "touch.*",
        "tr.*",
        "tree.*",
        "tsc.*",
        "turbo.*",
        "uniq.*",
        "unzip.*",
        "vite.*",
        "vitest.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "yarn.*",
        "zip.*",
        "zoxide.*"
      ],
      "deniedCommands": ["git push.*"],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "research",
        "reviewer",
        "planner",
        "go",
        "node",
        "react",
        "db"
      ],
      "trustedAgents": ["research"]
    }
  },
  "welcomeMessage": "What are we building?"
}
