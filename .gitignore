# SSH private hosts
.ssh/hosts
.ssh/config.work
.ssh/config.local
.ssh/id_*
.ssh/*.pem
.ssh/known_hosts*
.config/git/config.local
.config/tmux/plugins
.zshrc.local

# Override global gitignore — track .kiro/ in dotfiles
!.kiro/
!.claude/

# Kiro CLI runtime files (still ignore these)
.kiro/.cli_bash_history
.kiro/prompts
.kiro/settings/lsp.json
