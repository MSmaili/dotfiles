#!/usr/bin/env bash
set -euo pipefail

has() { command -v "$1" &>/dev/null; }

run_fmt() {
    local pattern="$1"; shift
    local matched=()

    while IFS= read -r file; do
        [[ "$file" =~ $pattern ]] && matched+=("$file")
    done < <(printf '%s\n' "${changed_files[@]}")

    [[ ${#matched[@]} -eq 0 ]] && return

    printf '%s\0' "${matched[@]}" | xargs -0 "$@"
}

FORMAT_GO=false
FORMAT_JS=false
FORMAT_LUA=false
FORMAT_SH=false

if [[ $# -eq 0 ]]; then
    FORMAT_GO=true; FORMAT_JS=true; FORMAT_LUA=true; FORMAT_SH=true
fi

for arg in "$@"; do
    case "$arg" in
        --go)      FORMAT_GO=true ;;
        --js|--ts) FORMAT_JS=true ;;
        --lua)     FORMAT_LUA=true ;;
        --sh)      FORMAT_SH=true ;;
        --all)     FORMAT_GO=true; FORMAT_JS=true; FORMAT_LUA=true; FORMAT_SH=true ;;
        --help|-h)
            printf 'Usage: %s [--go] [--js|--ts] [--lua] [--sh] [--all]\n' "$(basename "$0")"
            printf '  No args formats everything.\n'
            exit 0 ;;
        *) printf 'Unknown option: %s\n' "$arg" >&2; exit 1 ;;
    esac
done

has git || exit 0
cd "$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

mapfile -t changed_files < <(
    { git diff --name-only --diff-filter=ACMR
      git ls-files --others --exclude-standard
    } | sort -u
)

[[ ${#changed_files[@]} -eq 0 ]] && exit 0

if has npx; then
    run_fmt '\.(json|ya?ml|md)$'            npx prettier --write --cache
    $FORMAT_JS && run_fmt '\.(js|jsx|ts|tsx|css|scss)$' npx prettier --write --cache
fi

$FORMAT_GO  && has gofmt     && run_fmt '\.go$'         gofmt -w
$FORMAT_LUA && has stylua    && run_fmt '\.lua$'        stylua
$FORMAT_SH  && has beautysh  && run_fmt '\.(sh|bash)$'  beautysh
