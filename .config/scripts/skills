#!/usr/bin/env bash
set -e

GLOBAL_SKILLS=(
    "https://github.com/anthropics/skills --skill skill-creator"
    "https://github.com/anthropics/skills --skill docx"
    "https://github.com/anthropics/skills --skill frontend-design"
)

REACT_SKILLS=(
    "softaworks/agent-toolkit@react-useeffect"
    "https://github.com/vercel-labs/agent-skills --skill vercel-react-best-practices"
)

DB_SKILLS=(
    "https://github.com/supabase/agent-skills --skill supabase-postgres-best-practices"
    "https://github.com/planetscale/database-skills --skill mysql"
)

GO_SKILLS=(
    "https://github.com/affaan-m/everything-claude-code --skill golang-patterns"
    "https://github.com/affaan-m/everything-claude-code --skill api-design"
    "https://github.com/Jeffallan/claude-skills --skill golang-pro"
)

NODE_SKILLS=(
    "https://github.com/Jeffallan/claude-skills --skill nestjs-expert"
)

K8S_SKILLS=(
    "https://github.com/Jeffallan/claude-skills --skill kubernetes-specialist"
)

DOCS_SKILLS=(
    "https://github.com/anthropics/skills --skill docx"
    "https://github.com/anthropics/skills --skill pptx"
)

TARGETS=()

clean_skills() {
    echo "🧹 Cleaning skills..."
    for target in "${TARGETS[@]}"; do
        case "$target" in
            kiro)     echo "  → kiro";     npx skills remove --all --agent kiro-cli -y 2>/dev/null || true ;;
            claude)   echo "  → claude";   npx skills remove --all --agent claude-code -y 2>/dev/null || true ;;
            opencode) echo "  → opencode"; npx skills remove --all --agent opencode -y 2>/dev/null || true ;;
        esac
    done
    echo "✓ Clean"
}

install_skill() {
    local desc="$1"; shift
    echo "  → $desc"
    npx skills add $@ 2>/dev/null || echo "  ⚠ Failed: $desc"
}

install_group() {
    local -n skills_ref=$1
    local scope="$2"

    local g=""; [[ "$scope" == "global" ]] && g="-g"

    for entry in "${skills_ref[@]}"; do
        local name="${entry##*--skill }"
        [[ "$name" == "$entry" ]] && name="${entry##*/}"

        for target in "${TARGETS[@]}"; do
            case "$target" in
                kiro)     install_skill "$name (kiro)" $entry $g -a kiro-cli --copy -y ;;
                claude)   install_skill "$name (claude)" $entry $g -a claude-code --copy -y ;;
                opencode) install_skill "$name (opencode)" $entry $g -a opencode --copy -y ;;
            esac
        done
    done
}

usage() {
    cat <<EOF
Usage: skills [--target kiro|claude|opencode|all] [group...]

Targets:
  --target kiro      Kiro CLI only (.kiro/skills)
  --target claude    Claude Code only (.claude/skills)
  --target opencode  OpenCode only (~/.config/opencode/skills)
  --target all       All targets (default)

Groups:
  global    General-purpose skills (installed globally)
  react     React + TypeScript skills (installed locally)
  go        Go + API design skills (installed locally)
  node      Node/Bun backend skills (installed locally)
  k8s       Kubernetes specialist skills (installed locally)
  db        Database skills (installed locally)
  docs      Document generation skills (installed locally)
  all       All groups
  clean     Remove all installed skills for target(s)

No group = global only.

Examples:
  skills global                       # global, all targets
  skills react                        # react local, all targets
  skills --target kiro go k8s         # go+k8s, kiro only
  skills --target claude react db     # react+db local, claude only
  skills clean                        # clean all targets
  skills --target kiro clean          # clean kiro only
EOF
}

main() {
    if ! command -v npx &>/dev/null; then
        echo "⚠ npx not available"
        return 1
    fi

    local groups=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)
                shift
                case "${1:-}" in
                    kiro)     TARGETS+=(kiro) ;;
                    claude)   TARGETS+=(claude) ;;
                    opencode) TARGETS+=(opencode) ;;
                    all)      TARGETS=(kiro claude opencode) ;;
                    *)      error "Unknown target: ${1:-}"; usage; return 1 ;;
                esac
                ;;
            -h|--help) usage; return ;;
            *) groups+=("$1") ;;
        esac
        shift
    done

    [[ ${#TARGETS[@]} -eq 0 ]] && TARGETS=(kiro claude opencode)
    [[ ${#groups[@]} -eq 0 ]] && { usage; return; }

    for group in "${groups[@]}"; do
        case "$group" in
            global)  echo "🧠 Installing global skills...";        install_group GLOBAL_SKILLS global ;;
            react)   echo "⚛️  Installing React skills (local)...";   install_group REACT_SKILLS local ;;
            go)      echo "🐹 Installing Go skills (local)...";     install_group GO_SKILLS local ;;
            node)    echo "🟢 Installing Node skills (local)...";   install_group NODE_SKILLS local ;;
            k8s)     echo "☸️  Installing K8s skills (local)...";     install_group K8S_SKILLS local ;;
            db)      echo "🗄️  Installing DB skills (local)...";      install_group DB_SKILLS local ;;
            docs)    echo "📄 Installing Docs skills (local)...";    install_group DOCS_SKILLS local ;;
            clean)   clean_skills; return ;;
            all)     main "${TARGETS[@]/#/--target }" global react go node k8s db docs; return ;;
            *)      echo "Unknown group: $group"; usage; return 1 ;;
        esac
    done

    echo "✓ Done"
}

main "$@"
