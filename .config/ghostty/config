theme = Catppuccin Mocha
background-opacity = 0.90
background-blur = 30
background-blur-radius = 30
macos-titlebar-style = hidden
progress-style = true
macos-option-as-alt = true
# show the border around
macos-window-shadow = true
#minimum-contrast = 2
#bold-is-bright = true

# Fonts
font-family = "MonoLisaCode Variable"
font-size = 15
font-variation = wght=430
font-variation = GRAD=20
font-feature = calt, liga, zero, dlig, cv01, cv02, cv04, cv07, cv08, ss01, ss11, ss14

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
copy-on-select = true
cursor-invert-fg-bg = false
cursor-color = "#a6adc8"
cursor-text = "#1e1e2e"

window-padding-x = 5
window-padding-y = 5,1

#cilpboard
clipboard-write = allow
clipboard-read = allow

keybind = cmd+p=text:\x01o
