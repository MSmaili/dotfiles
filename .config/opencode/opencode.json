{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "external_directory": {
      "~/.zshrc.local": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "bash": {
      "*": "ask",
      "ast-grep*": "allow",
      "awk*": "allow",
      "biome*": "allow",
      "bun*": "allow",
      "cargo*": "allow",
      "cat*": "allow",
      "cloc*": "allow",
      "cp*": "allow",
      "date*": "allow",
      "diff*": "allow",
      "doggo*": "allow",
      "dot*": "allow",
      "fd*": "allow",
      "find*": "allow",
      "fnm*": "allow",
      "fzf*": "allow",
      "git*": "allow",
      "git push*": "ask",
      "git push": "ask",
      "go*": "allow",
      "grep*": "allow",
      "ripgrep*": "allow",
      "gsed*": "allow",
      "head*": "allow",
      "jq*": "allow",
      "ls*": "allow",
      "mkdir*": "allow",
      "npm*": "allow",
      "pnpm*": "allow",
      "prettier*": "allow",
      "pwd": "allow",
      "rg*": "allow",
      "sed*": "allow",
      "sg*": "allow",
      "shellcheck*": "allow",
      "sort*": "allow",
      "stow*": "allow",
      "stylua*": "allow",
      "tail*": "allow",
      "tar*": "allow",
      "touch*": "allow",
      "tr*": "allow",
      "tree*": "allow",
      "tsc*": "allow",
      "turbo*": "allow",
      "uniq*": "allow",
      "unzip*": "allow",
      "vite*": "allow",
      "vitest*": "allow",
      "wc*": "allow",
      "which*": "allow",
      "xargs*": "allow",
      "yarn*": "allow",
      "z*": "allow",
      "zip*": "allow",
      "zoxide*": "allow"
    },
    "edit": "ask",
    "webfetch": "ask"
  },
  "tools": {
    "context7*": false,
    "deepwiki*": false,
    "exa*": false,
    "fff*": true
  },
  "agent": {
    "general": {
      "mode": "primary",
      "description": "General development orchestrator. Prefer FFF for local search and delegate external research.",
      "prompt": "You are a general development assistant. For local repository searching, prefer fff_find_files, fff_grep, and fff_multi_grep over glob/grep. When the user needs documentation lookups, web search, or GitHub wiki/repo research, invoke the research subagent and return concise findings with source links.",
      "permission": {
        "task": {
          "*": "deny",
          "research": "allow"
        }
      }
    },
    "research": {
      "mode": "subagent",
      "description": "Search docs, web, and GitHub wikis using MCP tools.",
      "model": "opencode/minimax-m2.5-free",
      "prompt": "You are a research agent. For local repository discovery and code search, prefer fff_find_files, fff_grep, and fff_multi_grep. Use Context7 for library/framework docs and API references. Use DeepWiki for GitHub repository documentation. Use Exa for web search, blog posts, and current information. Pick the right tool for the question. Be concise and return relevant findings with source links.",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "context7*": true,
        "deepwiki*": true,
        "exa*": true,
        "fff*": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  },
  "plugin": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true
    }
  }
}
